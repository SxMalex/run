STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:8501
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2
CACHE_TTL=3600

# Poids de l'athlète en kg — utilisé pour le calcul des calories (défaut : 70)
ATHLETE_WEIGHT_KG=70

# Clé API OpenRouteService — nécessaire pour la page Prochaine sortie
# Inscription gratuite sur https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key
