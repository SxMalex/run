STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# En dev local : http://localhost:8501
# En prod : https://${PUBLIC_DOMAIN}/ (doit matcher l'Authorization Callback Domain Strava)
STRAVA_REDIRECT_URI=http://localhost:8501

CACHE_TTL=3600

# Clé API OpenRouteService — nécessaire pour la page Prochaine sortie
# Inscription gratuite sur https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key

# ─── Production uniquement (docker-compose.prod.yml) ─────────────────────
# Domaine public servi par Caddy avec HTTPS auto via Let's Encrypt
PUBLIC_DOMAIN=running.exemple.com
ACME_EMAIL=admin@exemple.com
